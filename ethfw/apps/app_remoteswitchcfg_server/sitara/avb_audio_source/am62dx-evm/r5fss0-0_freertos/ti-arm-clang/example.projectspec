<?xml version="1.0" encoding="UTF-8"?>
<projectSpec>
    <applicability>
        <when>
            <context
                deviceFamily="ARM"
                deviceId="Cortex R.am62Dx"
            />
        </when>
    </applicability>

    <project
        title="Ethfw Server Audio Source"
        name = "ethfw_server_audio_source_am62dx-evm_r5fss0-0_freertos_ti-arm-clang"
        products="sysconfig;com.ti.MCU_PLUS_SDK_AMXXX"
        configurations="
            Debug,
            Release,
        "
        connection="TIXDS110_Connection.xml"
        toolChain="TICLANG"
        cgtVersion="4.0.1"
        device="Cortex R.am62Dx"
        deviceCore="MAIN_PULSAR_Cortex_R5_0_0"
        ignoreDefaultDeviceSettings="true"
        ignoreDefaultCCSSettings="true"
        endianness="little"
        outputFormat="ELF"
        outputType="executable"

        compilerBuildOptions="
            -I${CG_TOOL_ROOT}/include/c
            -I${MCU_PLUS_SDK_PATH}/source
            -I${MCU_PLUS_SDK_PATH}/source/kernel/freertos/FreeRTOS-Kernel/include
            -I${MCU_PLUS_SDK_PATH}/source/kernel/freertos/portable/TI_ARM_CLANG/ARM_CR5F
            -I${MCU_PLUS_SDK_PATH}/source/kernel/freertos/config/am62dx/r5f
            -I${MCU_PLUS_SDK_PATH}/source/drivers
            -I${MCU_PLUS_SDK_PATH}/source/drivers/udma
            -I${MCU_PLUS_SDK_PATH}/source/drivers/hw_include
            -I${MCU_PLUS_SDK_PATH}/source/board/ethphy/port
            -I${MCU_PLUS_SDK_PATH}/source/board/ethphy/enet/rtos_drivers/include
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/core/utils/include
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/core
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/core/include
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/core/include/phy
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/core/include/core
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/soc/k3/am62dx
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/hw_include
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/hw_include/mdio/V4
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/eval_inc
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/eval_inc/tsn_l2
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/tsn_unibase
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/tsn_gptp
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/tsn_gptp/tilld
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/tsn_combase/tilld/sitara
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/tsn_gptp/gptpconf
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/tsn_uniconf
            -I${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/tsn_uniconf/yangs
            -I${MCU_PLUS_SDK_PATH}/source/networking/lwip/lwip-stack/src/include
            -I${MCU_PLUS_SDK_PATH}/source/networking/lwip/lwip-port/include
            -I${MCU_PLUS_SDK_PATH}/source/networking/lwip/lwip-port/freertos/include
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/core/lwipif/inc
            -I${MCU_PLUS_SDK_PATH}/source/networking/lwip/lwip-stack/contrib
            -I${MCU_PLUS_SDK_PATH}/source/networking/lwip/lwip-config/am62dx
            -I${MCU_PLUS_SDK_PATH}/source/networking/ethfw
            -I${MCU_PLUS_SDK_PATH}/source/networking/ethfw/utils/ethfw_abstract/sitara
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/core/lwipific_tap/inc
            -I${MCU_PLUS_SDK_PATH}/source/networking/enet/core/intercore/include
            -mcpu=cortex-r5
            -mfloat-abi=hard
            -mfpu=vfpv3-d16
            -mthumb
            -Wall
            -Werror
            -g
            -Wno-gnu-variable-sized-type-not-at-end
            -Wno-unused-function
            --include tsn_buildconf/sitara_buildconf.h
            -DUB_LOGCAT=5
            -DSOC_AM62DX
            -DENABLE_SCICLIENT_DIRECT
            -DR5F_CORE
            -DENET_ENABLE_PER_CPSW=1
            -DPRINT_FORMAT_NO_WARNING
            -DSITARA
            -DGPTP_ENABLED=1
            -DMCU_PLUS_SDK
            -DETHFW_PROXY_ARP_SUPPORT
            -DETHFW_INTERCORE_ETH_SUPPORT
            -DETHAPP_ENABLE_INTERCORE_ETH
            -DENABLE_ETHFW_PROXYARP
            -DCPU_mcu2_0
            -DETHAPP_ENABLE_IPERF_SERVER
            -DETHFW_GPTP_SUPPORT
            -DENABLE_MAC_ONLY_PORTS
            -DAVTP_ENABLED=1
            -DAVTP_TALKER_MODE
            -DNO_GETOPT_LONG=1
            -DAVTP_HAVE_NO_SIGNAL=1
            -DAVTP_DIRECT_MODE=1
            -DAUTOAMP_APP_ENABLED=1
        "
        linkerBuildOptions="
            -i${MCU_PLUS_SDK_PATH}/source/kernel/freertos/lib
            -i${MCU_PLUS_SDK_PATH}/source/drivers/lib
            -i${MCU_PLUS_SDK_PATH}/source/drivers/device_manager/sciserver/lib
            -i${MCU_PLUS_SDK_PATH}/source/drivers/device_manager/rm_pm_hal/lib
            -i${MCU_PLUS_SDK_PATH}/source/drivers/device_manager/sciclient_direct/lib
            -i${MCU_PLUS_SDK_PATH}/source/drivers/device_manager/self_reset/lib
            -i${MCU_PLUS_SDK_PATH}/source/drivers/device_manager/dm_stub/lib
            -i${MCU_PLUS_SDK_PATH}/source/board/lib
            -i${MCU_PLUS_SDK_PATH}/source/networking/enet/lib
            -i${MCU_PLUS_SDK_PATH}/source/networking/lwip/lib
            -i${MCU_PLUS_SDK_PATH}/source/networking/tsn/lib
            -i${MCU_PLUS_SDK_PATH}/source/networking/ethfw/lib
            -i${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/eval_lib
            -i${MCU_PLUS_SDK_PATH}/source/networking/tsn/tsn-stack/license_lib
            -i${CG_TOOL_ROOT}/lib
            -i${PROJECT_BUILD_DIR}/syscfg
            -m=ethfw_server_audio_source.${ConfigName}.map
            --diag_suppress=10063
            --priority
            --ram_model
            --reread_libs
            --zero_init=on
            --use_memset=fast
            --use_memcpy=fast
        "

        postBuildStep="$(MAKE) -C ${CCS_PROJECT_DIR} -f makefile_ccs_bootimage_gen OUTNAME=${BuildArtifactFileBaseName} PROFILE=${ConfigName} MCU_PLUS_SDK_PATH=${MCU_PLUS_SDK_PATH} CG_TOOL_ROOT=${CG_TOOL_ROOT} CCS_INSTALL_DIR=${CCS_INSTALL_DIR} CCS_IDE_MODE=${CCS_IDE_MODE}"

        enableSysConfigTool="true"
        sysConfigBuildOptions="
            --context r5fss0-0 --part AM62D24-G --package ANF
        "

        description="A Ethfw Server Audio Source FREERTOS project">

        <configuration name="Debug"
            compilerBuildOptions="
                -D_DEBUG_=1
            "
            linkerBuildOptions="
                -lrm_pm_hal.am62dx.r5f.ti-arm-clang.debug.lib
                -lsciclient_direct.am62dx.r5f.ti-arm-clang.debug.lib
                -lself_reset.am62dx.r5f.ti-arm-clang.debug.lib
                -lsciserver.am62dx.r5f.ti-arm-clang.debug.lib
                -lfreertos.am62dx.r5f.ti-arm-clang.debug.lib
                -ldrivers.am62dx.dm-r5f.ti-arm-clang.debug.lib
                -lboard.am62dx.r5f.ti-arm-clang.debug.lib
                -ldm_stub.am62dx.r5f.ti-arm-clang.debug.lib
                -lenet-cpsw.am62dx.r5f.ti-arm-clang.debug.lib
                -llibc.a
                -llibsysbm.a
                -ltsn_combase-freertos.am62dx.r5f.ti-arm-clang.debug.lib
                -ltsn_unibase-freertos.am62dx.r5f.ti-arm-clang.debug.lib
                -ltsn_gptp-freertos.am62dx.r5f.ti-arm-clang.debug.lib
                -ltsn_uniconf-freertos.am62dx.r5f.ti-arm-clang.debug.lib
                -ltsn_l2-freertos.am62dx.r5f.ti-arm-clang.lib
                -llwipif-cpsw-freertos.am62dx.r5f.ti-arm-clang.debug.lib
                -llwip-freertos.am62dx.r5f.ti-arm-clang.debug.lib
                -llwip-contrib-freertos.am62dx.r5f.ti-arm-clang.debug.lib
                -lethfw.am62dx.dm-r5f.ti-arm-clang.debug.lib
                -lyangemb-freertos.am62dx.r5f.ti-arm-clang.lib
                -llibc.a
                -llibsysbm.a
            "
        ></configuration>
        <configuration name="Release"
            compilerBuildOptions="
                -Os
                -Oz
                -flto
            "
            linkerBuildOptions="
                -lrm_pm_hal.am62dx.r5f.ti-arm-clang.release.lib
                -lsciclient_direct.am62dx.r5f.ti-arm-clang.release.lib
                -lself_reset.am62dx.r5f.ti-arm-clang.release.lib
                -lsciserver.am62dx.r5f.ti-arm-clang.release.lib
                -lfreertos.am62dx.r5f.ti-arm-clang.release.lib
                -ldrivers.am62dx.dm-r5f.ti-arm-clang.release.lib
                -lboard.am62dx.r5f.ti-arm-clang.release.lib
                -ldm_stub.am62dx.r5f.ti-arm-clang.release.lib
                -lenet-cpsw.am62dx.r5f.ti-arm-clang.release.lib
                -llibc.a
                -llibsysbm.a
                -ltsn_combase-freertos.am62dx.r5f.ti-arm-clang.release.lib
                -ltsn_unibase-freertos.am62dx.r5f.ti-arm-clang.release.lib
                -ltsn_gptp-freertos.am62dx.r5f.ti-arm-clang.release.lib
                -ltsn_uniconf-freertos.am62dx.r5f.ti-arm-clang.release.lib
                -ltsn_l2-freertos.am62dx.r5f.ti-arm-clang.lib
                -llwipif-cpsw-freertos.am62dx.r5f.ti-arm-clang.release.lib
                -llwip-freertos.am62dx.r5f.ti-arm-clang.release.lib
                -llwip-contrib-freertos.am62dx.r5f.ti-arm-clang.release.lib
                -lethfw.am62dx.dm-r5f.ti-arm-clang.release.lib
                -lyangemb-freertos.am62dx.r5f.ti-arm-clang.lib
                -llibc.a
                -llibsysbm.a
            "
        ></configuration>
        <pathVariable name="MCU_PLUS_SDK_PATH" path="${COM_TI_MCU_PLUS_SDK_AMXXX_INSTALL_DIR}" scope="project" />
        <file path="../../../../../../../../../../examples/drivers/boot/common/soc/am62dx/sbl_ospi_stage2.c" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="../../../../../../../../../../examples/drivers/boot/common/soc/am62dx/sbl_emmc_stage2.c" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="../../../../../../../../../../examples/drivers/boot/common/soc/am62dx/sbl_stage2_common.c" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="../main_server.c" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="../../../../../main.c" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="../../../../app_cpswconfighandler.c" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="../../../../ethfw_avtp.c" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="../../../../shm_cirbuf.c" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="linker.cmd" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="../example.syscfg" openOnCreation="false" excludeFromBuild="false" action="link">
        </file>
        <file path="${MCU_PLUS_SDK_PATH}/docs/api_guide_am62dx/EXAMPLES_ENET_CPSW_TSN_LWIP_GPTP.html"
                openOnCreation="false" excludeFromBuild="false" targetName="README.html" action="link">
        </file>
        <file path="syscfg_c.rov.xs" openOnCreation="false" excludeFromBuild="false" action="copy">
        </file>
        <file path="makefile_ccs_bootimage_gen" openOnCreation="false" excludeFromBuild="false" action="copy">
        </file>
    </project>
</projectSpec>
