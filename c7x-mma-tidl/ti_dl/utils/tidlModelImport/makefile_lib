##############################################################
ALGBASE_PATH ?= $(abspath ../../../)
PSDK_INSTALL_PATH ?= $(abspath ../../../../)
override BUILD_WITH_CUDA=0
override BUILD_WITH_OPENACC=0
COMMON_DIR= ../../../common

SUBDIRS= ../tfImport/proto_cc/tensorflow/core/framework
SUBDIRS+= ../onnxImport/onnx_cc/onnx
SUBDIRS+= ../tfImport/models_research_cc/object_detection/protos

CFILES := $(foreach dir,$(SUBDIRS),$(wildcard $(dir)/*.cc))
CFILES += ../caffeImport/caffe.pb.cc
CFILES += ../tidlMetaArch/tidl_meta_arch.pb.cc
CFILES += ../tidlQuantParams/tidl_quant_params.pb.cc


HFILES = ../caffeImport/caffe.pb.h
HFILES = ../tidlQuantParams/tidl_quant_params.pb.h
HFILES += ti_dl.h

TARGET_PLATFORM = PC
BUILD_WITH_CUDA = 0

ifdef SystemRoot
PROTOBUF_LIB_DIR?=$(TIDL_PROTOBUF_PATH)/lib/Release
PROTOBUF_INC_DIR?="$(TIDL_PROTOBUF_PATH)/src"
else
PROTOBUF_LIB_DIR?="$(TIDL_PROTOBUF_PATH)/src/.libs"
PROTOBUF_INC_DIR?="$(TIDL_PROTOBUF_PATH)/src"
endif


ifdef SystemRoot
OUTFILE= ./lib/tidl_model_protos.lib
else
OUTFILE= ./lib/libtidl_model_protos.a

endif

##############################################################

include $(ALGBASE_PATH)/makerules/rules.mk

#used inside makerules, but okay to define it afterwards
CFLAGS+= -I $(PROTOBUF_INC_DIR)
CFLAGS+= -I ../../inc
CFLAGS+= -I ../caffeImport
CFLAGS+= -I ../tidlMetaArch
CFLAGS+= -I ../tidlQuantParams
CFLAGS+= -I ../tfImport
CFLAGS+= -I ../tfImport/proto_cc
CFLAGS+= -I ../onnxImport/onnx_cc
CFLAGS+= -I ../tfImport/models_research_cc
CFLAGS += -I $(COMMON_DIR)
CFLAGS += -I ../perfsim


#CFLAGS+= /D_MSC_VER=1700 /Gd
ifdef SystemRoot
CFLAGS+= /DTIDL_IMPORT_TOOL
else
CFLAGS+= -DTIDL_IMPORT_TOOL
CFLAGS += -Werror=return-type -Wno-unused-result -Wno-format-overflow
endif

##############################################################


##############################################################
LIBDIR =  ".\lib"

$(OUTFILE) : libfile
##############################################################

