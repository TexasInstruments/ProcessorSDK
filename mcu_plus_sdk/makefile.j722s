BUILD_COMBO_freertos_fat = freertos_fat_r5f.ti-arm-clang
BUILD_COMBO_nortos = nortos_r5f.ti-arm-clang
BUILD_COMBO_freertos = freertos_r5f.ti-arm-clang freertos_c75x.ti-c7000
BUILD_COMBO_safertos = safertos_r5f.ti-arm-clang safertos_c75x.ti-c7000
BUILD_COMBO_dmautils = dmautils_c75ss0-0.ti-c7000 dmautils_c75ss1-0.ti-c7000
BUILD_COMBO_safety_checkers = safety_checkers_r5f.ti-arm-clang
BUILD_COMBO_pdm_utils = pdm_utils_wkup-r5fss0-0.ti-arm-clang pdm_utils_mcu-r5fss0-0.ti-arm-clang pdm_utils_main-r5fss0-0.ti-arm-clang pdm_utils_c75ss0-0.ti-c7000 pdm_utils_c75ss1-0.ti-c7000
BUILD_COMBO_sdl = sdl_mcu-r5f.ti-arm-clang
BUILD_COMBO_unity = unity_r5f.ti-arm-clang unity_a53.gcc-aarch64 unity_c75x.ti-c7000
BUILD_COMBO_rm_pm_hal = rm_pm_hal_wkup-r5f.ti-arm-clang
BUILD_COMBO_rm_pm_hal_sbl = rm_pm_hal_sbl_wkup-r5f.ti-arm-clang

# Combine all Components
BUILD_COMBO_ALL = $(BUILD_COMBO_board) $(BUILD_COMBO_drivers) $(BUILD_COMBO_self_reset) $(BUILD_COMBO_sciclient_direct) $(BUILD_COMBO_sciclient_direct_sbl) $(BUILD_COMBO_sciserver) $(BUILD_COMBO_freertos_fat) $(BUILD_COMBO_nortos) $(BUILD_COMBO_freertos) $(BUILD_COMBO_dmautils) $(BUILD_COMBO_safety_checkers) $(BUILD_COMBO_pdm_utils) $(BUILD_COMBO_sdl) $(BUILD_COMBO_unity) $(BUILD_COMBO_rm_pm_hal) $(BUILD_COMBO_rm_pm_hal_sbl)

