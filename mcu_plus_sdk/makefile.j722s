BUILD_COMBO_PREBUILT_SCRUB_ALL =

# Combine all Private Components Scrub Targets
BUILD_COMBO_PRIVATE_SCRUB_ALL = $(BUILD_COMBO_SCRUB_safertos)

libs-scrub: $(BUILD_COMBO_SCRUB_ALL)

libs-prebuilt-scrub: $(BUILD_COMBO_PREBUILT_SCRUB_ALL)

libs-private-scrub: $(BUILD_COMBO_PRIVATE_SCRUB_ALL)

$(BUILD_COMBO_SCRUB_board):
	$(MAKE) -C source/board -f makefile.j722s.$(subst board_,,$(subst _scrub,,$@)) scrub

$(BUILD_COMBO_SCRUB_drivers):
	$(MAKE) -C source/drivers -f makefile.j722s.$(subst drivers_,,$(subst _scrub,,$@)) scrub

$(BUILD_COMBO_SCRUB_self_reset):
	$(MAKE) -C source/drivers/device_manager/self_reset -f makefile.j722s.$(subst self_reset_,,$(subst _scrub,,$@)) scrub

$(BUILD_COMBO_SCRUB_sciclient_direct):
