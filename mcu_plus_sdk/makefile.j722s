# Combine all Private Components
BUILD_COMBO_PRIVATE_ALL = $(BUILD_COMBO_safertos)

libs: $(BUILD_COMBO_ALL)

libs-prebuilt: $(BUILD_COMBO_PREBUILT_ALL)

libs-private: $(BUILD_COMBO_PRIVATE_ALL)

$(BUILD_COMBO_board):
	$(MAKE) -C source/board -f makefile.j722s.$(subst board_,,$@) all

$(BUILD_COMBO_drivers):
	$(MAKE) -C source/drivers -f makefile.j722s.$(subst drivers_,,$@) all

