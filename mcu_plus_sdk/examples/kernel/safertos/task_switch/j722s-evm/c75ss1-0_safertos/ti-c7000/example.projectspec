<?xml version="1.0" encoding="UTF-8"?>
<projectSpec>
    <applicability>
        <when>
            <context
                deviceFamily="C7000"
                deviceId="TMS320C75XX.J722S"
            />
        </when>
    </applicability>

    <project
        title="Task Switch"
        name = "task_switch_j722s-evm_c75ss1-0_safertos_ti-c7000"
        products="sysconfig;com.ti.MCU_PLUS_SDK_AMXXX"
        configurations="
            Debug,
            Release,
        "
        connection="TIXDS110_Connection.xml"
        toolChain="TI"
        cgtVersion=""
        device="TMS320C75XX.J722S"
        deviceCore="DSP_Core_2"
        ignoreDefaultDeviceSettings="true"
        ignoreDefaultCCSSettings="true"
        endianness="little"
        outputFormat="ELF"
        outputType="executable"

        compilerBuildOptions="
            -I${CG_TOOL_ROOT}/include
            -I${MCU_PLUS_SDK_PATH}/source
            -I${MCU_PLUS_SDK_PATH}/source/kernel/safertos/c75/kernel/include_api
            -I${MCU_PLUS_SDK_PATH}/source/kernel/safertos/c75/api/230_C7x
            -I${MCU_PLUS_SDK_PATH}/source/kernel/safertos/c75/api/NoWrapper
            -I${MCU_PLUS_SDK_PATH}/source/kernel/safertos/c75/portable/230_C7x
            -I${MCU_PLUS_SDK_PATH}/source/kernel/safertos/c75/portable/230_C7x/005_TI_CGT
            -I${MCU_PLUS_SDK_PATH}/source/kernel/safertos/c75/config
            -DBUILD_C75X_2
            -mv7524
            --abi=eabi
            -q
            -mo
            -pden
            -pds=238
            -pds=880
            -pds1110
            --endian=little
            --disable_inlining
            -ea.se71
            --emit_warnings_as_errors
            --diag_suppress=770
            --diag_suppress=69
            --diag_suppress=70
            --advice:performance=none
            -DSOC_J722S
            -DOS_SAFERTOS
        "
        linkerBuildOptions="
            -i${MCU_PLUS_SDK_PATH}/source/kernel/safertos/lib
            -i${MCU_PLUS_SDK_PATH}/source/drivers/lib
            -i${MCU_PLUS_SDK_PATH}/source/board/lib
            -i${CG_TOOL_ROOT}/lib
            -m=task_switch.${ConfigName}.map
            --silicon_version=7524
            -z
            --emit_warnings_as_errors
            --diag_suppress=10063
            --ram_model
            --warn_sections
            -q
            -x
            
        "

        postBuildStep="$(MAKE) -C ${CCS_PROJECT_DIR} -f makefile_ccs_bootimage_gen OUTNAME=${BuildArtifactFileBaseName} PROFILE=${ConfigName} MCU_PLUS_SDK_PATH=${MCU_PLUS_SDK_PATH} CG_TOOL_ROOT=${CG_TOOL_ROOT} CCS_INSTALL_DIR=${CCS_INSTALL_DIR} CCS_IDE_MODE=${CCS_IDE_MODE}"

        enableSysConfigTool="true"
        sysConfigBuildOptions="
            --context c75ss1-0 --part Default --package AMW
        "

        description="A Task Switch SAFERTOS project">

        <configuration name="Debug"
            compilerBuildOptions="
                -Dxdc_target_name__=C71
                -D_DEBUG_=1
                --opt_level=0
                --symdebug:dwarf
                -DBUILD_C75X
            "
            linkerBuildOptions="
                -lsafertos.j722s.c75x.ti-c7000.debug.lib
                -ldrivers.j722s.c75ss1-0.ti-c7000.debug.lib
                -llibc.a
            "
        ></configuration>
        <configuration name="Release"
            compilerBuildOptions="
                -Dxdc_target_name__=C71
                --opt_level=3
                -DBUILD_C75X
            "
            linkerBuildOptions="
                -lsafertos.j722s.c75x.ti-c7000.release.lib
                -ldrivers.j722s.c75ss1-0.ti-c7000.release.lib
                -llibc.a
            "
        ></configuration>
        <pathVariable name="MCU_PLUS_SDK_PATH" path="${COM_TI_MCU_PLUS_SDK_AMXXX_INSTALL_DIR}" scope="project" />
        <file path="../../../task_switch.c" openOnCreation="false" excludeFromBuild="false" action="copy">
        </file>
        <file path="../main.c" openOnCreation="false" excludeFromBuild="false" action="copy">
        </file>
        <file path="linker.cmd" openOnCreation="false" excludeFromBuild="false" action="copy">
        </file>
        <file path="../example.syscfg" openOnCreation="false" excludeFromBuild="false" action="copy">
        </file>
        <file path="${MCU_PLUS_SDK_PATH}/docs/api_guide_j722s/EXAMPLES_KERNEL_SAFERTOS_TASK_SWITCH.html"
                openOnCreation="false" excludeFromBuild="false" targetName="README.html" action="link">
        </file>
        <file path="syscfg_c.rov.xs" openOnCreation="false" excludeFromBuild="false" action="copy">
        </file>
        <file path="makefile_ccs_bootimage_gen" openOnCreation="false" excludeFromBuild="false" action="copy">
        </file>
    </project>
</projectSpec>
