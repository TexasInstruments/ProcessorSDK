 * @cliArgs --device "J722S_TDA4VEN_TDA4AEN_AM67" --package "AMW" --part "Default" --context "wkup-r5fss0-0" --product "MCU_PLUS_SDK@07.03.01"
 * @versions {"tool":"1.20.0+3587"}
 */

/**
 * Import the modules used in this configuration.
 */
const flash       = scripting.addModule("/board/flash/flash", {}, false);
const flash1      = flash.addInstance();
const bootloader  = scripting.addModule("/drivers/bootloader/bootloader", {}, false);
const bootloader1 = bootloader.addInstance();
const bootloader2 = bootloader.addInstance();
const ddr         = scripting.addModule("/drivers/ddr/ddr", {}, false);
const ddr1        = ddr.addInstance();
const gtc         = scripting.addModule("/drivers/gtc/gtc");
const qos         = scripting.addModule("/drivers/qos/qos", {}, false);
const qos1        = qos.addInstance();
const udma        = scripting.addModule("/drivers/udma/udma", {}, false);
const udma1       = udma.addInstance();
const clock       = scripting.addModule("/kernel/dpl/clock");
const debug_log   = scripting.addModule("/kernel/dpl/debug_log");
const mpu_armv7   = scripting.addModule("/kernel/dpl/mpu_armv7", {}, false);
const mpu_armv71  = mpu_armv7.addInstance();
const mpu_armv72  = mpu_armv7.addInstance();
const mpu_armv73  = mpu_armv7.addInstance();
const mpu_armv74  = mpu_armv7.addInstance();
const mpu_armv75  = mpu_armv7.addInstance();
const mpu_armv76  = mpu_armv7.addInstance();
const mpu_armv77  = mpu_armv7.addInstance();
const mpu_armv78  = mpu_armv7.addInstance();
const mpu_armv79  = mpu_armv7.addInstance();
const mpu_armv710 = mpu_armv7.addInstance();
const mpu_armv711 = mpu_armv7.addInstance();
const mpu_armv712 = mpu_armv7.addInstance();
const mpu_armv713 = mpu_armv7.addInstance();
const mpu_armv714 = mpu_armv7.addInstance();
const mpu_armv715 = mpu_armv7.addInstance();
const mpu_armv716 = mpu_armv7.addInstance();

/**
 * Write custom configuration values to the imported modules.
 */
bootloader1.$name     = "CONFIG_BOOTLOADER0";
bootloader1.bootMedia = "MEM";

bootloader2.$name          = "CONFIG_BOOTLOADER_FLASH_DM";
bootloader2.appImageOffset = "0x80000";

bootloader2.flashDriver                                     = flash1;
flash1.$name                                                = "CONFIG_FLASH_SBL";
flash1.skipDeinitFromSbl                                    = true;
flash1.serialFlashDriver.$name                              = "board_flash_serialFlash_serialflash0";
flash1.serialFlashDriver.peripheralDriver.dmaEnable         = true;
flash1.serialFlashDriver.peripheralDriver.phyEnable         = true;
flash1.serialFlashDriver.peripheralDriver.$name             = "CONFIG_OSPI_SBL";
flash1.serialFlashDriver.peripheralDriver.skipDeinitFromSbl = true;

ddr1.$name             = "CONFIG_DDR0";
ddr1.eccEnableFlag     = true;
ddr1.eccEnd0           = 0x20000;
ddr1.eccStart1         = 0x20000;
ddr1.eccEnd1           = 0x40000;
ddr1.eccStart2         = 0x40000;
ddr1.eccEnd2           = 0x60000;
ddr1.skipDeinitFromSbl = true;

qos1.$name = "CONFIG_QOS0";

udma1.$name                                          = "CONFIG_UDMA0";
flash1.serialFlashDriver.peripheralDriver.udmaDriver = udma1;
udma1.skipDeinitFromSbl                              = true;

debug_log.enableUartLog             = true;
debug_log.enableCssLog              = false;
debug_log.enableLogZoneInfo         = true;
debug_log.uartLog.intrEnable        = "DISABLE";
debug_log.uartLog.$name             = "CONFIG_UART_SBL";
debug_log.uartLog.WKUP_UART.$assign = "WKUP_USART0";

mpu_armv71.allowExecute = false;
mpu_armv71.$name        = "REGISTER_REGION";
mpu_armv71.size         = 31;
mpu_armv71.attributes   = "Device";

mpu_armv72.baseAddr = 0x80000000;
mpu_armv72.size     = 31;
mpu_armv72.$name    = "DDR";

mpu_armv73.baseAddr   = 0x41010000;
mpu_armv73.size       = 15;
mpu_armv73.attributes = "NonCached";
mpu_armv73.$name      = "WKUP_R5_LOCAL_TCMB";

mpu_armv74.size       = 15;
mpu_armv74.$name      = "WKUP_R5_LOCAL_TCMA";
mpu_armv74.attributes = "NonCached";

mpu_armv75.baseAddr = 0x43C00000;
mpu_armv75.size     = 18;
mpu_armv75.$name    = "HSM_RAM";

mpu_armv76.$name    = "OCM_RAM";
mpu_armv76.size     = 18;
mpu_armv76.baseAddr = 0x43C40000;

mpu_armv77.$name      = "WKUP_R5_GLOBAL_TCMA";
mpu_armv77.baseAddr   = 0x78000000;
mpu_armv77.size       = 15;
mpu_armv77.attributes = "NonCached";

mpu_armv78.$name      = "MCU_R5_GLOBAL_TCMA";
mpu_armv78.baseAddr   = 0x79000000;
mpu_armv78.size       = 15;
mpu_armv78.attributes = "NonCached";

mpu_armv79.$name      = "MCU_R5_GLOBAL_TCMB";
mpu_armv79.baseAddr   = 0x79020000;
mpu_armv79.size       = 15;
mpu_armv79.attributes = "NonCached";

mpu_armv710.$name      = "MAIN_R5_GLOBAL_TCMA";
mpu_armv710.size       = 15;
mpu_armv710.attributes = "NonCached";
mpu_armv710.baseAddr   = 0x78400000;

mpu_armv711.$name      = "MAIN_R5_GLOBAL_TCMB";
mpu_armv711.baseAddr   = 0x78500000;
mpu_armv711.size       = 15;
mpu_armv711.attributes = "NonCached";

mpu_armv712.baseAddr   = 0x7E000000;
mpu_armv712.attributes = "NonCached";
mpu_armv712.$name      = "L2S_RAM_C75_0";
mpu_armv712.size       = 21;

mpu_armv713.$name      = "L2S_RAM_C75_1";
mpu_armv713.baseAddr   = 0x7E200000;
mpu_armv713.attributes = "NonCached";
mpu_armv713.size       = 21;

mpu_armv714.$name      = "OSPI_FLASH";
mpu_armv714.baseAddr   = 0x60000000;
mpu_armv714.size       = 26;
mpu_armv714.attributes = "NonCached";

mpu_armv715.$name        = "FSS0_OSPI0_CTRL_REG";
mpu_armv715.baseAddr     = 0xFC40000;
mpu_armv715.allowExecute = false;
mpu_armv715.size         = 8;
mpu_armv715.attributes   = "Device";

mpu_armv716.$name    = "MS_RAM";
mpu_armv716.baseAddr = 0x79100000;
mpu_armv716.size     = 19;

/**
 * Pinmux solution for unlocked pins/peripherals. This ensures that minor changes to the automatic solver in a future
 * version of the tool will not impact the pinmux you originally saw.  These lines can be completely deleted in order to
 * re-solve from scratch.
 */
flash1.serialFlashDriver.peripheralDriver.OSPI.$suggestSolution      = "OSPI0";
flash1.serialFlashDriver.peripheralDriver.OSPI.CLK.$suggestSolution  = "OSPI0_CLK";
flash1.serialFlashDriver.peripheralDriver.OSPI.CSn0.$suggestSolution = "OSPI0_CSn0";
flash1.serialFlashDriver.peripheralDriver.OSPI.DQS.$suggestSolution  = "OSPI0_DQS";
flash1.serialFlashDriver.peripheralDriver.OSPI.D7.$suggestSolution   = "OSPI0_D7";
flash1.serialFlashDriver.peripheralDriver.OSPI.D6.$suggestSolution   = "OSPI0_D6";
flash1.serialFlashDriver.peripheralDriver.OSPI.D5.$suggestSolution   = "OSPI0_D5";
flash1.serialFlashDriver.peripheralDriver.OSPI.D4.$suggestSolution   = "OSPI0_D4";
flash1.serialFlashDriver.peripheralDriver.OSPI.D3.$suggestSolution   = "OSPI0_D3";
flash1.serialFlashDriver.peripheralDriver.OSPI.D2.$suggestSolution   = "OSPI0_D2";
flash1.serialFlashDriver.peripheralDriver.OSPI.D1.$suggestSolution   = "OSPI0_D1";
flash1.serialFlashDriver.peripheralDriver.OSPI.D0.$suggestSolution   = "OSPI0_D0";
debug_log.uartLog.WKUP_UART.RXD.$suggestSolution                     = "WKUP_UART0_RXD";
debug_log.uartLog.WKUP_UART.TXD.$suggestSolution                     = "WKUP_UART0_TXD";
